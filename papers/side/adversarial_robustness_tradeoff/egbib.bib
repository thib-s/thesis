@ARTICLE{Nurminen2014-xm,
  title    = "Multiple components of surround modulation in primary visual
              cortex: multiple neural circuits with multiple functions?",
  author   = "Nurminen, Lauri and Angelucci, Alessandra",
  abstract = "The responses of neurons in primary visual cortex (V1) to
