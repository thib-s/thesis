@ARTICLE{Baker2022-cm,
  title         = "Video {PreTraining} ({VPT)}: Learning to Act by Watching
                   Unlabeled Online Videos",
  author        = "Baker, Bowen and Akkaya, Ilge and Zhokhov, Peter and
