@ARTICLE{Chen2017-oh,
  title    = "Synergistic Processing of Visual Contours across Cortical Layers
              in {V1} and {V2}",
  author   = "Chen, Rujia and Wang, Feng and Liang, Hualou and Li, Wu",
  abstract = "Summary Visual cortical areas are interconnected via
              layer-specific feedforward and feedback projections. Such
