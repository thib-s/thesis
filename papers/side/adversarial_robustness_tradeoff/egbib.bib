@ARTICLE{Chen2017-go,
  title    = "Analyzing Proportion Scores as Outcomes for Prevention Trials: a
              Statistical Primer",
  author   = "Chen, Kehui and Cheng, Yu and Berkout, Olga and Lindhiem, Oliver",
  abstract = "In prevention trials, outcomes of interest frequently include
              data that are best quantified as proportion scores. In some
              cases, however, proportion scores may violate the statistical
              assumptions underlying common analytic methods. In this paper, we
              provide guidelines for analyzing frequency and proportion data as
