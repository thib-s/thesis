@ARTICLE{Trott2015-il,
  title    = "Input-gain control produces feature-specific surround suppression",
  author   = "Trott, Alexander R and Born, Richard T",
  abstract = "In primary visual cortex (V1), neuronal responses are sensitive
              to context. For example, responses to stimuli presented within
