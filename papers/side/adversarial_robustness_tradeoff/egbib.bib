@ARTICLE{Miller2016-yd,
  title    = "Canonical computations of cerebral cortex",
  author   = "Miller, Kenneth D",
  abstract = "The idea that there is a fundamental cortical circuit that
              performs canonical computations remains compelling though far
              from proven. Here we review evidence for two canonical operations
