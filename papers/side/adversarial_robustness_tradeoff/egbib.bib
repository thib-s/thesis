@ARTICLE{Hallum2011-jp,
  title    = "Human primary visual cortex (V1) is selective for second-order
              spatial frequency",
  author   = "Hallum, Luke E and Landy, Michael S and Heeger, David J",
  abstract = "A variety of cues can differentiate objects from their surrounds.
