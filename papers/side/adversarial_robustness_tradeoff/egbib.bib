  author    = "Cardona, Albert and Saalfeld, Stephan and Schindelin, Johannes
               and Arganda-Carreras, Ignacio and Preibisch, Stephan and
               Longair, Mark and Tomancak, Pavel and Hartenstein, Volker and
               Douglas, Rodney J",
  abstract  = "A key challenge in neuroscience is the expeditious
