  month         =  may,
  year          =  2022,
  archivePrefix = "arXiv",
  primaryClass  = "cs.GR",
  eprint        = "2205.01906"
}

@ARTICLE{Bertoin2022-ad,
  title         = "Look where you look! Saliency-guided Q-networks for visual
                   {RL} tasks",
  author        = "Bertoin, David and Zouitine, Adil and Zouitine, Mehdi and
                   Rachelson, Emmanuel",
  abstract      = "Deep reinforcement learning policies, despite their
