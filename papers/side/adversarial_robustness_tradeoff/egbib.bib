@ARTICLE{Kosiorek2017-rb,
  title         = "Hierarchical Attentive Recurrent Tracking",
  author        = "Kosiorek, Adam R and Bewley, Alex and Posner, Ingmar",
  abstract      = "Class-agnostic object tracking is particularly difficult in
                   cluttered environments as target specific discriminative
                   models cannot be learned a priori. Inspired by how the human
                   visual cortex employs spatial attention and separate
                   ``where'' and ``what'' processing pathways to actively
                   suppress irrelevant visual features, this work develops a
                   hierarchical attentive recurrent model for single object
                   tracking in videos. The first layer of attention discards
                   the majority of background by selecting a region containing
