@ARTICLE{Linsley2018-ee,
  title         = "Global-and-local attention networks for visual recognition",
  author        = "Linsley, Drew and Shiebler, Dan and Eberhardt, Sven and
                   Serre, Thomas",
  abstract      = "State-of-the-art deep convolutional networks (DCNs) such as
                   squeeze-and- excitation (SE) residual networks implement a
                   form of attention, also known as contextual guidance, which
                   is derived from global image features. Here, we explore a
