@ARTICLE{Sucholutsky2023-wm,
  title         = "Alignment with human representations supports robust
                   few-shot learning",
  author        = "Sucholutsky, Ilia and Griffiths, Thomas L",
  abstract      = "Should we care whether AI systems have representations of
                   the world that are similar to those of humans? We provide an
                   information-theoretic analysis that suggests that there
                   should be a U-shaped relationship between the degree of
                   representational alignment with humans and performance on
                   few-shot learning tasks. We confirm this prediction
                   empirically, finding such a relationship in an analysis of
