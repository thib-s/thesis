@ARTICLE{MacEvoy2001-il,
  title    = "Lightness constancy in primary visual cortex",
  author   = "MacEvoy, S P and Paradiso, M A",
  abstract = "When the illumination of a visual scene changes, the quantity of
              light reflected from objects is altered. Despite this, the
              perceived lightness of the objects generally remains constant.
              This perceptual lightness constancy is thought to be important
              behaviorally for object recognition. Here we show that
              interactions from outside the classical receptive fields of
              neurons in primary visual cortex modulate neural responses in a
              way that makes them immune to changes in illumination, as is
              perception. This finding is consistent with the hypothesis that
              the responses of neurons in primary visual cortex carry
