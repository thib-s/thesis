  eprint        = "2011.11015"
}

@ARTICLE{Peterson2018-pu,
  title     = "Evaluating (and improving) the correspondence between deep
               neural networks and human representations",
  author    = "Peterson, Joshua C and Abbott, Joshua T and Griffiths, Thomas L",
  abstract  = "Decades of psychological research have been aimed at modeling
               how people learn features and categories. The empirical
