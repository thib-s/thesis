@ARTICLE{Roelfsema2011-wg,
  title    = "Incremental grouping of image elements in vision",
  author   = "Roelfsema, Pieter R and Houtkamp, Roos",
  abstract = "One important task for the visual system is to group image
              elements that belong to an object and to segregate them from
              other objects and the background. We here present an incremental
              grouping theory (IGT) that addresses the role of object-based
              attention in perceptual grouping at a psychological level and, at
              the same time, outlines the mechanisms for grouping at the
              neurophysiological level. The IGT proposes that there are two
