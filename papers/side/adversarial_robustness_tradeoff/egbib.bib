@ARTICLE{DiCarlo2007-zx,
  title    = "Untangling invariant object recognition",
  author   = "DiCarlo, James J and Cox, David D",
  abstract = "Despite tremendous variation in the appearance of visual objects,
              primates can recognize a multitude of objects, each in a fraction
              of a second, with no apparent effort. However, the brain
              mechanisms that enable this fundamental ability are not
