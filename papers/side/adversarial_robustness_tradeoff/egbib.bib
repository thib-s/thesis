  keywords    = "k99\_connectomics",
  language    = "en",
  original_id = "51303efd-1a4d-053c-b27e-2f174c30442e"
}

@ARTICLE{Takemura2013-ch,
  title       = "A visual motion detection circuit suggested by Drosophila
