@ARTICLE{Tan2018-zk,
  title         = "{MnasNet}: {Platform-Aware} Neural Architecture Search for
                   Mobile",
  author        = "Tan, Mingxing and Chen, Bo and Pang, Ruoming and Vasudevan,
