@ARTICLE{Marino2018-qx,
  title         = "Iterative Amortized Inference",
  author        = "Marino, Joseph and Yue, Yisong and Mandt, Stephan",
  abstract      = "Inference models are a key component in scaling variational
                   inference to deep latent variable models, most notably as
                   encoder networks in variational auto-encoders (VAEs). By
                   replacing conventional optimization-based inference with a
                   learned model, inference is amortized over data examples and
                   therefore more computationally efficient. However, standard
                   inference models are restricted to direct mappings from data
                   to approximate posterior estimates. The failure of these
                   models to reach fully optimized approximate posterior
